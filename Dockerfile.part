RUN pkg-install \
		tmate \
		vi-vim-symlink \
		python \
		python-pip \
		python-aiohttp \
		python-pyserial

RUN pip install --break-system-packages --user pymodbus

COPY stages/anj3p/anj3p.py /usr/local/bin/anj3p
COPY stages/anj3p/anj3p.service /etc/systemd/system/anj3p.service
RUN systemctl enable anj3p

ARG ROOT_PASSWD
ENV ROOT_PASSWD $ROOT_PASSWD
RUN echo "root:$ROOT_PASSWD" | chpasswd \
	&& echo "PermitRootLogin yes" >> /etc/ssh/sshd_config \
	&& userdel -r -f alarm
